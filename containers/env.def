Bootstrap: docker
# Choose your image. Here uv on alpine using python3.13
From: ghcr.io/astral-sh/uv:python3.13-alpine

%files
    # Copy your dependency files from the host into the container
    pyproject.toml /app/pyproject.toml
    # Uncomment the next line if you also use a lockfile for exact reproducibility
    # uv.lock /app/uv.lock

%post
    # Move into the app directory
    cd /app

    # Create the virtual environment inside the container
    uv venv /opt/venv
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"

    # Install dependencies directly from the pyproject.toml
    # uv is smart enough to parse pyproject.toml if passed with -r
    uv pip install -r pyproject.toml

    # (Optional) Clean up the cache to make the .sif file smaller
    uv cache clean

%environment
    # Ensure the container always uses this environment when running
    export VIRTUAL_ENV=/opt/venv
    export PATH="/opt/venv/bin:$PATH"
